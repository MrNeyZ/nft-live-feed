{
  "name": "nft-live-feed",
  "version": "0.1.0",
  "description": "Solana-wide live NFT sales feed backend",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --exec ts-node src/index.ts",
    "start": "node dist/index.js",
    "migrate": "ts-node src/db/migrate.ts",
    "backfill:me": "ts-node src/scripts/backfill-collection-sales.ts",
    "debug:mints:launchpads": "ts-node src/scripts/debug-mints-launchpads.ts",
    "debug:mints:supply": "ts-node src/scripts/debug-mints-supply.ts",
    "debug:mints:launchpad-survey": "ts-node src/scripts/debug-mints-launchpad-survey.ts"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  }
}
