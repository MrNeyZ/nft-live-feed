+// ── Shared Pill ─────────────────────────────────────────────────────────────
+//
+// Unified pill / filter-button / tab primitive. Replaces the near-identical
+// inline-styled buttons that were copy-pasted across Live Feed filters,
+// Dashboard filters / tabs / timeframe pills, and the Collection page's
+// FilterBtn. Purple is the default; callers pass a `color` for category-
+// tinted variants (Buys = green, Sells = red, ME = pink, etc.).
+//
+// The `size` prop picks one of two padding + font presets so the same
+// primitive covers the `3px 10px / fs 10-11` filter-pill geometry and the
+// tighter `2px 8px / fs 10` collection-filter geometry without a one-off
+// style. Radius is normalized to 4 across every call site.
+export function Pill({
+  active, onClick, color = '#a890e8', size = 'md', title, children,
+}: {
+  active: boolean;
+  onClick: () => void;
+  /** Hex (no alpha) — drives border + background tint + text color when active. */
+  color?: string;
+  /** `md` matches feed/dashboard filter pills; `sm` matches collection filter pills. */
+  size?: 'sm' | 'md';
+  title?: string;
+  children: React.ReactNode;
+}) {
+  const pad    = size === 'sm' ? '2px 8px' : '3px 10px';
+  const fs     = size === 'sm' ? 10        : 10;
+  const weight = 600;
+  return (
+    <button
+      onClick={onClick}
+      title={title}
+      style={{
+        padding: pad, fontSize: fs, fontWeight: weight, borderRadius: 4,
+        border: `1px solid ${active ? color + '66' : 'rgba(255,255,255,0.08)'}`,
+        background: active ? color + '22' : 'rgba(255,255,255,0.02)',
+        color: active ? color : '#8f8fa8',
+        cursor: 'pointer',
+        fontFamily: 'inherit',
+        letterSpacing: '0.3px',
+        transition: 'all 0.12s',
+      }}>
+      {children}
+    </button>
+  );
+}
